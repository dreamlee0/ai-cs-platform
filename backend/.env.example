# Application
APP_NAME=AI Customer Service Platform
DEBUG=true

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# Redis (optional)
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0

# JWT - CHANGE THIS IN PRODUCTION
SECRET_KEY=your-super-secret-key-change-me

# LLM Configuration
# Provider: openai, zhipu, qwen, ollama
LLM_PROVIDER=openai
LLM_API_KEY=sk-your-api-key-here
LLM_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-3.5-turbo
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# Embedding Model
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Knowledge Base
KNOWLEDGE_BASE_DIR=./knowledge_base
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# System Prompt
SYSTEM_PROMPT=你是一个专业的AI智能客服助手。请根据知识库中的信息，礼貌、准确地回答用户的问题。

# Transfer Settings
TRANSFER_KEYWORDS=人工客服,转人工,人工,客服,投诉

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
